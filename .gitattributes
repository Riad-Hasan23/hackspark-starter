# Enforce LF line endings for all text files
# This is critical for Windows users developing for Linux Docker containers
* text=auto eol=lf

# Explicitly set common web/backend files
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.dockerignore text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf
.env.example text eol=lf
.gitignore text eol=lf